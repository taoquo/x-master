{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "jsx": "react-jsx",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "types": [
      "chrome",
      "node"
    ],
    "allowImportingTsExtensions": true
  },
  "include": [
    ".plasmo/index.d.ts",
    "src/**/*",
    "tests/**/*",
    "plasmo.config.ts"
  ]
}
